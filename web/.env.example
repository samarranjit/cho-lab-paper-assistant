# ── Supabase ──────────────────────────────────────────────────────────────────
# Base project URL — do NOT include /rest/v1/
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Cloudflare Workers AI ─────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# LLM for answer generation (default shown)
CLOUDFLARE_LLM_MODEL=@cf/meta/llama-3.1-8b-instruct-fp8-fast

# Embedding model used when EMBEDDING_PROVIDER=cloudflare
CLOUDFLARE_EMBEDDING_MODEL=@cf/baai/bge-base-en-v1.5

# ── Embedding provider ────────────────────────────────────────────────────────
# "cloudflare" = Cloudflare handles query embeddings (default, works on Vercel)
# "local_http"  = your lab embedding server handles query embeddings
#
# IMPORTANT: with "cloudflare", your lab computer does NOT need to run at runtime.
# It only needs to run when you ingest new papers.
EMBEDDING_PROVIDER=cloudflare

# Only set these when EMBEDDING_PROVIDER=local_http
LOCAL_EMBEDDING_API_URL=
LOCAL_EMBEDDING_API_KEY=

# ── Retrieval tuning ──────────────────────────────────────────────────────────
MATCH_COUNT=6
MATCH_THRESHOLD=0.35
